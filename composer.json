{
    "name": "karumi-dev/shopify-connector.git",
    "description": "A Shopify integration package for Unopim, enabling seamless product data synchronization between Unopim and Shopify.",
    "type": "library",
    "license": "MIT",    
    "authors": [
        {
            "name": "UnoPim",
            "email": "support@webkul.com"
        }
    ],
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/karumi-dev/shopify-connector.git"
        }
    ],
    "autoload": {
        "psr-4": {
            "Webkul\\Shopify\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webkul\\Shopify\\Providers\\ShopifyServiceProvider"
            ],
            "aliases": {}
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@php artisan vendor:publish --tag=config --force",
            "@php artisan shopify-package:install"
        ]
    },
    "minimum-stability": "dev"    
}
